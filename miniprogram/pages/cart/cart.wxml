<view class="page cart-page">
  <view class="cart-head">
    <text>购物车</text>
    <text class="clear" bindtap="clearCart">清空</text>
  </view>

  <view wx:if="{{!items.length}}" class="empty">购物车还是空的</view>
  <view wx:else>
    <view wx:for="{{items}}" wx:key="id" class="cart-item card">
      <view class="item-main">
        <view class="name">{{item.name}}</view>
        <view class="muted">单价 ￥{{item.amount}}</view>
      </view>
      <view class="qty">x{{item.number}}</view>
    </view>
  </view>

  <view class="bottom-bar" wx:if="{{items.length}}">
    <view>
      <view class="muted">合计</view>
      <view class="total">￥{{total}}</view>
    </view>
    <button class="primary-btn checkout" bindtap="checkout">去结算</button>
  </view>
</view>
