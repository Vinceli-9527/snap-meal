.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 4rpx 28rpx;
}

.hello {
  font-size: 40rpx;
  font-weight: 900;
}

.sub {
  margin-top: 8rpx;
  color: #8a8f98;
}

.badge {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  color: #ff6b35;
  background: #fff4ee;
  font-weight: 700;
}

.search {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 28rpx;
  border-radius: 40rpx;
  background: #fff;
  color: #b0b5bd;
}

.tabs {
  white-space: nowrap;
  margin: 28rpx 0;
}

.tab {
  display: inline-block;
  margin-right: 18rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #5f6670;
  font-weight: 700;
}

.tab.active {
  background: #ff6b35;
  color: #fff;
}

.section-head {
  display: flex;
  justify-content: space-between;
  margin: 8rpx 0 20rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.more {
  color: #ff6b35;
  font-size: 24rpx;
  font-weight: 700;
}

.dish-card {
  display: flex;
  gap: 22rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.dish-image {
  width: 168rpx;
  height: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f5f5f5;
  font-size: 48rpx;
  overflow: hidden;
}

.dish-image image {
  width: 100%;
  height: 100%;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 31rpx;
  font-weight: 800;
}

.sales {
  margin-top: 12rpx;
  color: #9aa0a6;
  font-size: 24rpx;
}

.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
}

.add-btn {
  width: 58rpx;
  height: 58rpx;
  line-height: 52rpx;
  padding: 0;
  border-radius: 50%;
  background: #ff6b35;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
}
