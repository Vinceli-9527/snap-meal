.login-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 120rpx 48rpx 48rpx;
  background: linear-gradient(180deg, #fff4ee 0%, #f7f7f7 48%);
}

.brand-card {
  padding: 72rpx 40rpx;
  text-align: center;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 20rpx 50rpx rgba(255, 107, 53, 0.14);
}

.mark {
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  margin: 0 auto 28rpx;
  border-radius: 32rpx;
  background: #ff6b35;
  color: #fff;
  font-weight: 900;
  font-size: 36rpx;
}

.brand {
  font-size: 52rpx;
  font-weight: 900;
}

.slogan {
  margin-top: 16rpx;
  color: #7b8088;
  font-size: 28rpx;
}

.login-btn {
  margin-top: 56rpx;
}

.hint {
  margin-top: 28rpx;
  text-align: center;
  color: #9aa0a6;
  font-size: 24rpx;
}
