.login-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 120rpx 48rpx 48rpx;
  background: #0f1d16;
}

.brand-card {
  padding: 72rpx 40rpx;
  text-align: center;
  background: #f3f0e8;
  border: 1rpx solid #deddd4;
}

.mark {
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  margin: 0 auto 28rpx;
  background: #315943;
  color: #ffffff;
  font-weight: 900;
  font-size: 36rpx;
}

.brand {
  font-size: 52rpx;
  font-weight: 900;
}

.slogan {
  margin-top: 16rpx;
  color: #59635c;
  font-size: 28rpx;
}

.login-btn {
  margin-top: 56rpx;
}

.hint {
  margin-top: 28rpx;
  text-align: center;
  color: #c6d4c9;
  font-size: 24rpx;
}
