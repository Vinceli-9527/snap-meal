.title {
  margin: 8rpx 0 24rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.row {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
}

.thumb {
  width: 144rpx;
  height: 144rpx;
  line-height: 144rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #f5f5f5;
  font-size: 42rpx;
}

.info {
  flex: 1;
}

.name {
  font-weight: 800;
  font-size: 30rpx;
}

.desc {
  margin-top: 10rpx;
  color: #8a8f98;
  font-size: 24rpx;
}

.bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.mini-add {
  width: 54rpx;
  height: 54rpx;
  line-height: 48rpx;
  padding: 0;
  border-radius: 50%;
  background: #ff6b35;
  color: #fff;
  font-size: 36rpx;
}
