.page {
  padding: 0 0 36rpx;
  background: #fbfaf5;
}

.category-hero {
  padding: 32rpx 36rpx 34rpx;
  margin-bottom: 28rpx;
  background: #315943;
  color: #ffffff;
}

.back-link {
  display: inline-flex;
  padding: 12rpx 20rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, .38);
  color: #ffffff;
  font-size: 23rpx;
}

.hero-meta {
  color: #c6d4c9;
  font-size: 24rpx;
}

.title {
  margin-top: 8rpx;
  font-family: "Times New Roman", "Songti SC", serif;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.12;
}

.tagline {
  margin-top: 8rpx;
  font-size: 27rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 20rpx;
  margin: 0 28rpx 18rpx;
  background: #ffffff;
  border: 1rpx solid #e0ded5;
  animation: dish-rise 360ms cubic-bezier(.22, 1, .36, 1) both;
}

.thumb {
  width: 154rpx;
  height: 134rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #dbe3d6;
  color: #18211b;
  font-size: 48rpx;
  overflow: hidden;
}

.thumb image {
  width: 100%;
  height: 100%;
}

.info {
  flex: 1;
  min-width: 0;
}

.name {
  color: #18211b;
  font-family: "Times New Roman", "Songti SC", serif;
  font-weight: 800;
  font-size: 31rpx;
  line-height: 1.25;
}

.desc {
  margin-top: 10rpx;
  color: #687168;
  font-size: 22rpx;
  line-height: 1.45;
}

.bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
}

.mini-add {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: #d7f06b;
  color: #18211b;
  font-size: 36rpx;
  font-weight: 800;
}

@keyframes dish-rise {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
