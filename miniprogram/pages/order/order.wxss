.title {
  margin: 12rpx 0 24rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.order {
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.number {
  flex: 1;
  min-width: 0;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  color: #ff6b35;
  font-weight: 800;
}

.meta {
  margin: 24rpx 0 10rpx;
}
