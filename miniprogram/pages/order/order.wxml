<view class="page">
  <view class="title">我的订单</view>
  <view wx:if="{{!orders.length}}" class="empty">暂无订单</view>
  <view wx:for="{{orders}}" wx:key="id" class="order card">
    <view class="top">
      <text class="number">{{item.number}}</text>
      <text class="status">{{item.statusText}}</text>
    </view>
    <view class="meta">金额 <text class="price">￥{{item.amount}}</text></view>
    <view class="muted">{{item.order_time || item.orderTime || ''}}</view>
  </view>
</view>
