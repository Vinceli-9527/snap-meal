<view class="page address-page">
  <view class="head">
    <text>收货地址</text>
    <button class="ghost-btn add" bindtap="addAddress">新增地址</button>
  </view>

  <view wx:if="{{!addresses.length}}" class="empty">暂无地址，请先添加收货地址</view>
  <view wx:for="{{addresses}}" wx:key="id" class="addr-card card">
    <view class="top">
      <text class="name">{{item.consignee}}</text>
      <text>{{item.phone}}</text>
    </view>
    <view class="detail">{{item.province_name || item.provinceName}}{{item.city_name || item.cityName}}{{item.district_name || item.districtName}}{{item.detail}}</view>
  </view>
</view>
