page {
  background: #f7f7f7;
  color: #222;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 10rpx 28rpx rgba(30, 30, 30, 0.06);
}

.primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #ff6b35;
  color: #fff;
  font-weight: 700;
  font-size: 30rpx;
}

.ghost-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 44rpx;
  background: #fff4ee;
  color: #ff6b35;
  font-weight: 700;
}

.muted {
  color: #8a8f98;
}

.empty {
  padding: 88rpx 24rpx;
  text-align: center;
  color: #9aa0a6;
  font-size: 28rpx;
}

.price {
  color: #ff6b35;
  font-weight: 800;
}
