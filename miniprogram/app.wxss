page {
  background: #fbfaf5;
  color: #18211b;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.card {
  background: #fff;
  border: 1rpx solid #e0ded5;
  border-radius: 0;
  box-shadow: none;
}

.primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 0;
  background: #18211b;
  color: #fff;
  font-weight: 700;
  font-size: 30rpx;
}

.ghost-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 0;
  border: 1rpx solid #18211b;
  background: transparent;
  color: #18211b;
  font-weight: 700;
}

.muted {
  color: #687168;
}

.empty {
  padding: 88rpx 24rpx;
  text-align: center;
  color: #687168;
  font-size: 28rpx;
}

.price {
  color: #18211b;
  font-weight: 800;
}
